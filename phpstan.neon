parameters:
    level: max

    paths:
        - src
        - tests

    bootstrapFiles:
        - vendor/autoload.php

    treatPhpDocTypesAsCertain: false

    reportUnmatchedIgnoredErrors: false

    parallel:
        maximumNumberOfProcesses: 8

    scanDirectories:
        - vendor/phpstan/phpstan-deprecation-rules
        - vendor/phpstan/phpstan-strict-rules
        - vendor/ergebnis/phpstan-rules

    ignoreErrors:
        # PSR-16 CacheInterface dictates nullable type + null default
        # signatures on implementation methods. Cannot be changed without
        # breaking PSR-16 compliance. Documented on the class via @internal.
        -
            message: '#InMemoryTokenCache.*has parameter \$default with null as default value#'
            path: src/Auth/InMemoryTokenCache.php
        -
            message: '#InMemoryTokenCache.*has parameter \$ttl with a nullable type declaration#'
            path: src/Auth/InMemoryTokenCache.php
        -
            message: '#InMemoryTokenCache.*has parameter \$ttl with null as default value#'
            path: src/Auth/InMemoryTokenCache.php
        # OrgaMaxConfig::__construct takes nullable optional PSR-18 / PSR-17 /
        # cache / token-provider slots by design — they are resolved to
        # sensible defaults inside OrgaMaxClient::fromConfig(). Nullable params
        # are part of the public factory contract and cannot be replaced with
        # distinct types without forcing every caller to provide a value.
        -
            message: '#OrgaMaxConfig.*has parameter \$httpClient with a nullable type declaration#'
            path: src/OrgaMaxConfig.php
        -
            message: '#OrgaMaxConfig.*has parameter \$requestFactory with a nullable type declaration#'
            path: src/OrgaMaxConfig.php
        -
            message: '#OrgaMaxConfig.*has parameter \$streamFactory with a nullable type declaration#'
            path: src/OrgaMaxConfig.php
        -
            message: '#OrgaMaxConfig.*has parameter \$tokenCache with a nullable type declaration#'
            path: src/OrgaMaxConfig.php
        -
            message: '#OrgaMaxConfig.*has parameter \$tokenProvider with a nullable type declaration#'
            path: src/OrgaMaxConfig.php
        # PSR-7/PSR-18 test doubles (FakeStream, FakeResponse,
        # FakeResponseWithBody) implement external interfaces that mandate
        # nullable type declarations (e.g. getMetadata(?string $key = null))
        # and constructor defaults; cannot be refactored.
        -
            message: '#Tests.Fixtures.TestDouble.Fake(Response|Stream).*#'
            path: tests/Fixtures/TestDouble
        # OrgaMaxAuthenticatorTest uses an anonymous RuntimeException to
        # simulate the upstream PSR-18 HttpClient throwing on transport errors.
        -
            message: '#Anonymous class is not allowed to extend "RuntimeException"#'
            path: tests/Auth/OrgaMaxAuthenticatorTest.php

    ergebnis:
        noExtends:
            classesAllowedToBeExtended:
                - RuntimeException
                - Exception
                - BytesCommerce\Orgamax\Exception\OrgaMaxException
                - BytesCommerce\Orgamax\Exception\NoPreviousThrowable
        final:
            allowAbstractClasses: true
            classesNotRequiredToBeAbstractOrFinal: []
        noParameterWithContainerTypeDeclaration:
            interfacesImplementedByContainers: []
            methodsAllowedToUseContainerTypeDeclarations: []
