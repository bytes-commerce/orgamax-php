{
    "name": "bytes-commerce/orgamax-php",
    "description": "Modern, framework-agnostic PHP 8.3+ client for the OrgaMax Cloud OpenAPI — issue bearer tokens, manage articles, customers, invoices, orders, offers, expenses, files, suppliers, todos, tags, settings and bookkeeping charts of accounts.",
    "keywords": [
        "orgamax",
        "erp",
        "api-client",
        "bytes-commerce",
        "php83"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bytes Commerce (bytes-commerce.de)",
            "homepage": "https://bytes-commerce.de",
            "role": "Owner"
        }
    ],
    "support": {
        "issues": "https://github.com/bytes-commerce/orgamax-php/issues",
        "source": "https://github.com/bytes-commerce/orgamax-php",
        "email": "support@bytes-commerce.de"
    },
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "php-http/discovery": "^1.19",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/simple-cache": "^3.0",
        "webmozart/assert": "^1.11"
    },
    "require-dev": {
        "ergebnis/phpstan-rules": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-deprecation-rules": "^1.2",
        "phpstan/phpstan-strict-rules": "^1.6",
        "phpstan/phpstan-webmozart-assert": "^1.2",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^1.2",
        "symplify/easy-coding-standard": "^12.3"
    },
    "autoload": {
        "psr-4": {
            "BytesCommerce\\Orgamax\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BytesCommerce\\Orgamax\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true,
        "preferred-install": {
            "*": "dist"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "ecs": "vendor/bin/ecs check src tests --no-progress-bar",
        "ecs:fix": "vendor/bin/ecs check src tests --fix --no-progress-bar",
        "rector:dry": "vendor/bin/rector process src tests --dry-run --no-progress-bar"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
